---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Card from '../../components/ui/Card.astro';
import { getTranslation, getLocalePath, getLocaleRouteParams } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return getLocaleRouteParams();
}

const locale = (Astro.props.locale ?? "zh-TW") as Locale;
const t = getTranslation(locale);
const page = t.assessmentPage;
---

<BaseLayout title={t.meta.assessment.title} description={t.meta.assessment.description} locale={locale} currentPath="/assessment">
  <PageLayout locale={locale} currentPath="/assessment">

    <HeroSection headline={page.hero.headline} subtitle={page.hero.subtitle} />

    <!-- Assessment Preview -->
    <section class="py-24">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="glass-card p-8 sm:p-10">
          <div class="mb-6 text-center">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-accent/10 text-accent text-sm font-medium">
              {locale === 'zh-TW' ? '即將推出' : 'Coming Soon'}
            </span>
          </div>
          <h2 class="text-2xl font-bold text-foreground text-center mb-6">
            {locale === 'zh-TW' ? '互動式評估問卷' : 'Interactive Assessment'}
          </h2>
          <div class="space-y-3 mb-8">
            {page.questions.map((q: { question: string }, i: number) => (
              <div class="flex items-center gap-3 p-4 rounded-xl border border-white/6 bg-white/[0.03]">
                <span class="w-7 h-7 rounded-full bg-primary/10 flex items-center justify-center text-primary text-sm font-bold shrink-0">{i + 1}</span>
                <span class="text-sm text-muted-foreground">{q.question}</span>
              </div>
            ))}
          </div>
          <div class="text-center">
            <a href={getLocalePath(locale, '/contact')} class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-primary text-white font-medium hover:bg-primary/90 transition-colors glow-cyan">
              {locale === 'zh-TW' ? '聯絡我們取得評估' : 'Contact Us for Assessment'}
            </a>
          </div>
        </div>
      </div>
    </section>

    <CTASection
      headline={page.results.title}
      primaryLabel={page.results.ctaText}
      primaryHref={getLocalePath(locale, '/contact')}
    />

  </PageLayout>
</BaseLayout>
