---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import CTASection from '../../components/sections/CTASection.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import { getTranslation, getLocalePath, getLocaleRouteParams } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return getLocaleRouteParams();
}

const locale = (Astro.props.locale ?? "zh-TW") as Locale;
const t = getTranslation(locale);
---

<BaseLayout title={t.meta.integrations.title} description={t.meta.integrations.description} locale={locale} currentPath="/integrations">
  <PageLayout locale={locale} currentPath="/integrations">

    <HeroSection headline={t.integrations.hero.headline} subtitle={t.integrations.hero.subtitle} />

    <!-- Integration Categories -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {t.integrations.categories.map((cat) => (
            <div class="glass-card p-6">
              <h3 class="text-lg font-semibold text-foreground mb-4">{cat.name}</h3>
              <div class="flex flex-wrap gap-2">
                {cat.items.map((item) => (
                  <span class="px-3 py-1.5 text-sm rounded-lg bg-white/5 border border-white/10 text-muted-foreground">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Open API -->
    <section class="py-20 bg-surface-panel border-y border-white/5">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-foreground mb-4 text-center">{t.integrations.openApi.title}</h2>
        <p class="text-muted-foreground text-center mb-8">{t.integrations.openApi.description}</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {t.integrations.openApi.items.map((item) => (
            <div class="flex items-center gap-3 p-4 rounded-xl border border-white/10 bg-white/5">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-sm text-foreground">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      headline={t.integrations.cta.headline}
      primaryLabel={t.integrations.cta.ctaPrimary}
      primaryHref={getLocalePath(locale, '/contact')}
      secondaryLabel={t.integrations.cta.ctaSecondary}
      secondaryHref={getLocalePath(locale, '/contact')}
    />

  </PageLayout>
</BaseLayout>
