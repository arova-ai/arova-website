---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Card from '../../components/ui/Card.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import CTASection from '../../components/sections/CTASection.astro';
import ArchitectureDiagram from '../../components/visuals/ArchitectureDiagram.astro';
import { getTranslation, getLocalePath, getLocaleRouteParams } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return getLocaleRouteParams();
}

const locale = (Astro.props.locale ?? "zh-TW") as Locale;
const t = getTranslation(locale);
---

<BaseLayout title={t.meta.platform.title} description={t.meta.platform.description} locale={locale} currentPath="/platform">
  <PageLayout locale={locale} currentPath="/platform">

    <!-- Hero -->
    <HeroSection headline={t.platform.hero.headline} subtitle={t.platform.hero.subtitle} />

    <!-- What is Arova Nexus -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
          <div>
            <div class="w-1 h-12 bg-primary rounded-full mb-6" />
            <h2 class="text-3xl font-bold text-foreground mb-4">{t.platform.whatIs.title}</h2>
            <p class="text-muted-foreground leading-relaxed">{t.platform.whatIs.description}</p>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-foreground mb-6">{t.platform.whatIs.whyTitle}</h3>
            <ul class="space-y-4">
              {t.platform.whatIs.whyPoints.map((point) => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  <span class="text-muted-foreground">{point}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture Overview -->
    <section class="py-24 bg-surface-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={t.platform.architecture.title} />
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <ArchitectureDiagram layers={t.platform.architecture.layers} />
          <div class="grid sm:grid-cols-2 gap-4">
            {t.platform.architecture.layers.map((layer) => (
              <Card>
                <h3 class="text-sm font-semibold text-foreground mb-2">{layer.name}</h3>
                <p class="text-xs text-muted-foreground leading-relaxed">{layer.description}</p>
              </Card>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Deployment & Security -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={t.platform.deployment.title} />
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {t.platform.deployment.items.map((item) => (
            <div class="flex items-start gap-3 p-5 rounded-xl border border-white/10 bg-white/5">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
              <div>
                <h3 class="text-sm font-semibold text-foreground mb-1">{item.title}</h3>
                <p class="text-xs text-muted-foreground">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTASection
      headline={t.platform.cta.headline}
      primaryLabel={t.platform.cta.ctaPrimary}
      primaryHref={getLocalePath(locale, '/contact')}
      secondaryLabel={t.platform.cta.ctaSecondary}
      secondaryHref={getLocalePath(locale, '/contact')}
    />

  </PageLayout>
</BaseLayout>
