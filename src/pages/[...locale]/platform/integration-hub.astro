---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageLayout from '../../../components/layout/PageLayout.astro';
import HeroSection from '../../../components/sections/HeroSection.astro';
import CTASection from '../../../components/sections/CTASection.astro';
import SectionTitle from '../../../components/ui/SectionTitle.astro';
import Card from '../../../components/ui/Card.astro';
import { getTranslation, getLocalePath, getLocaleRouteParams } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';

export function getStaticPaths() {
  return getLocaleRouteParams();
}

const locale = (Astro.props.locale ?? "zh-TW") as Locale;
const t = getTranslation(locale);
const mod = t.platformModules.integrationHub;
---

<BaseLayout title={t.meta.platformIntegrationHub.title} description={t.meta.platformIntegrationHub.description} locale={locale} currentPath="/platform/integration-hub">
  <PageLayout locale={locale} currentPath="/platform/integration-hub">

    <HeroSection headline={mod.hero.headline} subtitle={mod.hero.subtitle} />

    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          {mod.features.map((f) => (
            <Card>
              <h3 class="text-lg font-semibold text-foreground mb-2">{f.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{f.description}</p>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <CTASection headline={mod.cta.headline} primaryLabel={mod.cta.button} primaryHref={getLocalePath(locale, '/contact')} />

  </PageLayout>
</BaseLayout>
