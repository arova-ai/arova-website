---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageLayout from '../../../components/layout/PageLayout.astro';
import HeroSection from '../../../components/sections/HeroSection.astro';
import CTASection from '../../../components/sections/CTASection.astro';
import SectionTitle from '../../../components/ui/SectionTitle.astro';
import Card from '../../../components/ui/Card.astro';
import { getTranslation, getLocalePath, getLocaleRouteParams } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';

export function getStaticPaths() {
  return getLocaleRouteParams();
}

const locale = (Astro.props.locale ?? "zh-TW") as Locale;
const t = getTranslation(locale);
const page = t.nexusIntelligencePage;
---

<BaseLayout title={t.meta.nexusIntelligence.title} description={t.meta.nexusIntelligence.description} locale={locale} currentPath="/platform/nexus-intelligence">
  <PageLayout locale={locale} currentPath="/platform/nexus-intelligence">

    <HeroSection headline={page.hero.headline} subtitle={page.hero.subtitle} />

    <!-- Reasoning Flow -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={page.reasoningFlow.title} subtitle={page.reasoningFlow.subtitle} />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 stagger-children">
          {page.reasoningFlow.steps.map((step: { name: string; label: string; description: string }, i: number) => (
            <div class="glass-card p-5 text-center relative">
              <div class="text-xs font-bold text-primary uppercase tracking-wider mb-1">{step.label}</div>
              <div class="text-sm font-semibold text-foreground mb-2">{step.name}</div>
              <p class="text-xs text-muted-foreground leading-relaxed">{step.description}</p>
              {i < page.reasoningFlow.steps.length - 1 && (
                <div class="hidden lg:block absolute top-1/2 -right-3 text-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Components -->
    <section class="py-24 bg-surface-panel section-gradient-top">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={page.techComponents.title} />
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          {page.techComponents.items.map((item: { name: string; label: string; description: string }) => (
            <Card>
              <div class="text-xs font-mono text-primary mb-2">{item.label}</div>
              <h3 class="text-lg font-semibold text-foreground mb-2">{item.name}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{item.description}</p>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <!-- Governance-First -->
    <section class="py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={page.governanceFirst.title} subtitle={page.governanceFirst.subtitle} />
        <div class="grid sm:grid-cols-2 gap-4 stagger-children">
          {page.governanceFirst.items.map((item: string) => (
            <div class="flex items-start gap-3 p-5 rounded-xl border border-white/6 bg-white/[0.03]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
              <span class="text-sm text-muted-foreground">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="py-24 bg-surface-panel section-gradient-top">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={page.comparison.title} />
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/10">
                {page.comparison.headers.map((h: string, i: number) => (
                  <th class={`text-left py-3 px-4 font-medium ${i === 1 ? 'text-primary' : 'text-muted-foreground'}`}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {page.comparison.rows.map((row: any) => {
                const cells: string[] = Array.isArray(row) ? row : Object.values(row);
                return (
                  <tr class="border-b border-white/5">
                    {cells.map((cell: string, i: number) => (
                      <td class={`py-3 px-4 ${i === 0 ? 'text-foreground font-medium' : i === 1 ? 'text-primary' : 'text-muted-foreground'}`}>{cell}</td>
                    ))}
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <CTASection
      headline={page.cta.headline}
      primaryLabel={page.cta.ctaPrimary}
      primaryHref={getLocalePath(locale, '/contact')}
      secondaryLabel={page.cta.ctaSecondary}
      secondaryHref={getLocalePath(locale, '/resources')}
    />

  </PageLayout>
</BaseLayout>
