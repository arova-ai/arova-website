---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import { getTranslation, getLocaleRouteParams } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return getLocaleRouteParams();
}

const locale = (Astro.props.locale ?? "zh-TW") as Locale;
const t = getTranslation(locale);
---

<BaseLayout title={t.meta.about.title} description={t.meta.about.description} locale={locale} currentPath="/about">
  <PageLayout locale={locale} currentPath="/about">

    <HeroSection headline={t.about.hero.headline} subtitle={t.about.hero.subtitle} />

    <!-- Brand Story -->
    <section class="py-24">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-foreground mb-6">{t.about.brandStory.title}</h2>
        {t.about.brandStory.content.split('\n\n').map((paragraph) => (
          <p class="text-muted-foreground leading-relaxed mb-4">{paragraph}</p>
        ))}
      </div>
    </section>

    <!-- Mission & Vision -->
    <section class="py-20 bg-surface-panel border-y border-white/5">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={t.about.missionVision.title} />
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="p-8 rounded-2xl glass-card">
            <div class="text-sm font-semibold text-primary mb-3">{t.about.missionVision.mission.label}</div>
            <p class="text-foreground text-lg leading-relaxed">{t.about.missionVision.mission.text}</p>
          </div>
          <div class="p-8 rounded-2xl glass-card">
            <div class="text-sm font-semibold text-accent mb-3">{t.about.missionVision.vision.label}</div>
            <p class="text-foreground text-lg leading-relaxed">{t.about.missionVision.vision.text}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Security -->
    <section class="py-24">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-foreground mb-6">{t.about.security.title}</h2>
        <p class="text-muted-foreground leading-relaxed">{t.about.security.content}</p>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="py-20 bg-surface-panel border-y border-white/5">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-foreground mb-8">{t.about.contact.title}</h2>
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <a href={`mailto:${t.about.contact.businessEmail}`} class="text-muted-foreground hover:text-foreground transition-colors">{t.about.contact.businessEmail}</a>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <a href={`mailto:${t.about.contact.supportEmail}`} class="text-muted-foreground hover:text-foreground transition-colors">{t.about.contact.supportEmail}</a>
          </div>
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-muted-foreground">{t.about.contact.address}</span>
          </div>
        </div>
      </div>
    </section>

  </PageLayout>
</BaseLayout>
