---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Card from '../../components/ui/Card.astro';
import { locales, getTranslation, getLocalePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslation(locale);
const blog = t.blog;
const filters: string[] = Array.isArray(blog.filters) ? blog.filters : (blog.filters?.categories ?? []);
---

<BaseLayout title={t.meta.blog.title} description={t.meta.blog.description} locale={locale} currentPath="/blog">
  <PageLayout locale={locale} currentPath="/blog">

    <HeroSection headline={blog.hero.headline} subtitle={blog.hero.subtitle} />

    <!-- Filter Buttons -->
    <section class="py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap justify-center gap-3">
          {filters.map((filter: string) => (
            <button class="px-4 py-2 rounded-full text-sm font-medium border border-white/10 bg-white/5 text-muted-foreground hover:text-foreground hover:border-primary/50 transition-colors">
              {filter}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Article Cards -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          {blog.articles.map((article: { title: string; category: string; date: string; readTime: string; description: string }) => (
            <Card class="flex flex-col cursor-pointer group">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary">{article.category}</span>
                <span class="text-xs text-muted-foreground">{article.readTime}</span>
              </div>
              <h3 class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors mb-2">{article.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed mb-4 flex-1">{article.description}</p>
              <div class="text-xs text-muted-foreground">{article.date}</div>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      headline={blog.cta.headline}
      primaryLabel={blog.cta.button}
      primaryHref={getLocalePath(locale, '/contact')}
    />

  </PageLayout>
</BaseLayout>
