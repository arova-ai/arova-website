---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import CTASection from '../../components/sections/CTASection.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Card from '../../components/ui/Card.astro';
import { locales, getTranslation, getLocalePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslation(locale);
---

<BaseLayout title={t.meta.forItOperations.title} description={t.meta.forItOperations.description} locale={locale} currentPath="/for-it-operations">
  <PageLayout locale={locale} currentPath="/for-it-operations">

    <HeroSection headline={t.forItOperations.hero.headline} subtitle={t.forItOperations.hero.subtitle} />

    <section class="py-20 bg-surface-panel border-y border-white/5">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={t.forItOperations.painPoints.title} />
        <div class="space-y-3">
          {t.forItOperations.painPoints.items.map((item) => (
            <div class="flex items-start gap-3 p-4 rounded-xl border border-destructive/20 bg-destructive/5">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-destructive shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
              <span class="text-sm text-muted-foreground">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={t.forItOperations.value.title} />
        <div class="grid sm:grid-cols-2 gap-6">
          {t.forItOperations.value.items.map((item) => (
            <Card>
              <div class="flex items-start justify-between mb-3">
                <h3 class="text-lg font-semibold text-foreground">{item.title}</h3>
                <span class="px-2.5 py-0.5 text-xs rounded-full bg-emerald-400/10 text-emerald-400 shrink-0 ml-3">{item.metric}</span>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed">{item.description}</p>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      headline={t.forItOperations.cta.headline}
      primaryLabel={t.forItOperations.cta.ctaPrimary}
      primaryHref={getLocalePath(locale, '/contact')}
      secondaryLabel={t.forItOperations.cta.ctaSecondary}
      secondaryHref={getLocalePath(locale, '/contact')}
    />

  </PageLayout>
</BaseLayout>
