---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import { locales, getTranslation } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslation(locale);
const f = t.contact.form.fields;
---

<BaseLayout title={t.meta.contact.title} description={t.meta.contact.description} locale={locale} currentPath="/contact">
  <PageLayout locale={locale} currentPath="/contact">

    <HeroSection headline={t.contact.hero.headline} subtitle={t.contact.hero.subtitle} />

    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-foreground mb-10 text-center">{t.contact.form.title}</h2>
        <div class="grid lg:grid-cols-5 gap-12">
          <!-- Form (3 cols) -->
          <div class="lg:col-span-3">
            <form class="space-y-6" onsubmit="event.preventDefault();">
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-foreground mb-2">{f.name.label}</label>
                  <input type="text" placeholder={f.name.placeholder} class="w-full px-4 py-2.5 rounded-xl bg-input border border-white/10 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-sm" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-foreground mb-2">{f.company.label}</label>
                  <input type="text" placeholder={f.company.placeholder} class="w-full px-4 py-2.5 rounded-xl bg-input border border-white/10 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-sm" />
                </div>
              </div>
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-foreground mb-2">{f.jobTitle.label}</label>
                  <input type="text" placeholder={f.jobTitle.placeholder} class="w-full px-4 py-2.5 rounded-xl bg-input border border-white/10 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-sm" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-foreground mb-2">{f.email.label}</label>
                  <input type="email" placeholder={f.email.placeholder} class="w-full px-4 py-2.5 rounded-xl bg-input border border-white/10 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-sm" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-foreground mb-2">{f.phone.label}</label>
                <input type="tel" placeholder={f.phone.placeholder} class="w-full px-4 py-2.5 rounded-xl bg-input border border-white/10 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-foreground mb-2">{f.challenge.label}</label>
                <textarea rows="4" placeholder={f.challenge.placeholder} class="w-full px-4 py-2.5 rounded-xl bg-input border border-white/10 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-sm resize-none"></textarea>
              </div>
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-foreground mb-2">{f.deploymentType.label}</label>
                  <select class="w-full px-4 py-2.5 rounded-xl bg-input border border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-sm">
                    <option value="" disabled selected>{f.deploymentType.placeholder}</option>
                    {f.deploymentType.options.map((opt) => (
                      <option value={opt}>{opt}</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-foreground mb-2">{f.timeline.label}</label>
                  <select class="w-full px-4 py-2.5 rounded-xl bg-input border border-white/10 text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-sm">
                    <option value="" disabled selected>{f.timeline.placeholder}</option>
                    {f.timeline.options.map((opt) => (
                      <option value={opt}>{opt}</option>
                    ))}
                  </select>
                </div>
              </div>
              <div class="flex flex-col sm:flex-row gap-4 pt-2">
                <button type="submit" class="px-8 py-3 bg-primary text-white rounded-full font-medium hover:bg-primary/90 transition-colors glow-cyan">
                  {t.contact.form.submit}
                </button>
                <button type="button" class="px-8 py-3 border border-white/20 text-foreground rounded-full font-medium hover:bg-white/5 transition-colors">
                  {t.contact.form.bookDemo}
                </button>
              </div>
              <p class="text-sm text-muted-foreground">{t.contact.form.successMessage}</p>
            </form>
          </div>

          <!-- Side Content (2 cols) -->
          <div class="lg:col-span-2 space-y-6">
            {t.contact.sideContent.map((item) => (
              <div class="p-6 rounded-xl glass-card">
                <h3 class="text-lg font-semibold text-foreground mb-2">{item.title}</h3>
                <p class="text-sm text-muted-foreground leading-relaxed">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

  </PageLayout>
</BaseLayout>
