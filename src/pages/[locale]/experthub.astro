---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import CTASection from '../../components/sections/CTASection.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Card from '../../components/ui/Card.astro';
import { locales, getTranslation, getLocalePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslation(locale);
---

<BaseLayout title={t.meta.experthub.title} description={t.meta.experthub.description} locale={locale} currentPath="/experthub">
  <PageLayout locale={locale} currentPath="/experthub">

    <HeroSection headline={t.experthub.hero.headline} subtitle={t.experthub.hero.subtitle} />

    <!-- Marketplace -->
    <section class="py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-foreground mb-4">{t.experthub.marketplace.title}</h2>
        <p class="text-muted-foreground leading-relaxed mb-8">{t.experthub.marketplace.description}</p>
        <div class="space-y-3">
          {t.experthub.marketplace.items.map((item) => (
            <div class="flex items-center gap-3 p-4 rounded-xl border border-white/10 bg-white/5">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-sm text-foreground">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Documents -->
    <section class="py-20 bg-surface-panel border-y border-white/5">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-foreground mb-4">{t.experthub.documents.title}</h2>
        <p class="text-muted-foreground mb-8">{t.experthub.documents.description}</p>
        <div class="grid sm:grid-cols-3 gap-4">
          {t.experthub.documents.items.map((doc) => (
            <Card class="text-center cursor-pointer group">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
              </div>
              <h3 class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors mb-1">{doc.title}</h3>
              <span class="text-xs text-muted-foreground">{doc.type}</span>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      headline={t.experthub.cta.headline}
      primaryLabel={t.experthub.cta.button}
      primaryHref="#"
    />

  </PageLayout>
</BaseLayout>
