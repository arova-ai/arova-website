---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageLayout from '../../../components/layout/PageLayout.astro';
import HeroSection from '../../../components/sections/HeroSection.astro';
import CTASection from '../../../components/sections/CTASection.astro';
import SectionTitle from '../../../components/ui/SectionTitle.astro';
import Card from '../../../components/ui/Card.astro';
import { locales, getTranslation, getLocalePath } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslation(locale);
const sol = t.solutionPages.compliance;
---

<BaseLayout title={t.meta.solutionCompliance.title} description={t.meta.solutionCompliance.description} locale={locale} currentPath="/solutions/compliance">
  <PageLayout locale={locale} currentPath="/solutions/compliance">

    <HeroSection headline={sol.hero.headline} subtitle={sol.hero.subtitle}>
      <div class="mt-6">
        <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-medium">{sol.hero.metric}</span>
      </div>
    </HeroSection>

    <!-- Scenarios -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-3 gap-6 stagger-children">
          {sol.scenarios.map((s: { title: string; description: string }) => (
            <Card>
              <h3 class="text-lg font-semibold text-foreground mb-2">{s.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{s.description}</p>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <!-- Workflow -->
    <section class="py-24 bg-surface-panel section-gradient-top">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle title={sol.workflow.title} />
        <div class="flex flex-wrap justify-center gap-3 stagger-children">
          {sol.workflow.steps.map((step: string, i: number) => (
            <div class="flex items-center gap-2">
              <span class="flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-sm text-foreground">
                <span class="w-6 h-6 rounded-full bg-primary/20 text-primary flex items-center justify-center text-xs font-bold">{i + 1}</span>
                {step}
              </span>
              {i < sol.workflow.steps.length - 1 && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary/50 hidden sm:block"><path d="m9 18 6-6-6-6"/></svg>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Capabilities -->
    <section class="py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-2 gap-4 stagger-children">
          {sol.capabilities.map((cap: string) => (
            <div class="flex items-center gap-3 p-4 rounded-xl border border-white/6 bg-white/[0.03]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-sm text-foreground">{cap}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Metrics -->
    <section class="py-20 bg-surface-panel section-gradient-top">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
          {sol.metrics.map((m: { value: string; label: string }) => (
            <div class="glass-card p-6 text-center">
              <div class="stat-value text-3xl mb-2">{m.value}</div>
              <div class="text-sm text-muted-foreground">{m.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      headline={sol.cta.headline}
      primaryLabel={sol.cta.ctaPrimary}
      primaryHref={getLocalePath(locale, '/contact')}
      secondaryLabel={sol.cta.ctaSecondary}
      secondaryHref={getLocalePath(locale, '/contact')}
    />

  </PageLayout>
</BaseLayout>
