---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../components/layout/PageLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import CTASection from '../../components/sections/CTASection.astro';
import { locales, getTranslation, getLocalePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslation(locale);
---

<BaseLayout title={t.meta.caseStudies.title} description={t.meta.caseStudies.description} locale={locale} currentPath="/case-studies">
  <PageLayout locale={locale} currentPath="/case-studies">

    <HeroSection headline={t.caseStudies.hero.headline} subtitle={t.caseStudies.hero.subtitle} />

    <section class="py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
        {t.caseStudies.items.map((cs, i) => (
          <article class="glass-card p-8 sm:p-10">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary font-bold">
                {i + 1}
              </div>
              <h2 class="text-xl sm:text-2xl font-bold text-foreground">{cs.title}</h2>
            </div>

            <div class="space-y-6">
              <div>
                <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-2">{locale === 'zh-TW' ? '背景' : 'Background'}</h3>
                <p class="text-muted-foreground leading-relaxed">{cs.background}</p>
              </div>

              <div>
                <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-2">{locale === 'zh-TW' ? '挑戰' : 'Challenge'}</h3>
                <p class="text-muted-foreground leading-relaxed">{cs.challenge}</p>
              </div>

              <div>
                <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-2">{locale === 'zh-TW' ? '導入方式' : 'Implementation'}</h3>
                <p class="text-muted-foreground leading-relaxed">{cs.implementation}</p>
              </div>

              <div>
                <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-2">{locale === 'zh-TW' ? '成果' : 'Outcomes'}</h3>
                <ul class="space-y-2">
                  {cs.outcomes.map((outcome) => (
                    <li class="flex items-start gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                      <span class="text-foreground text-sm">{outcome}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <CTASection
      headline={t.caseStudies.cta.headline}
      primaryLabel={t.caseStudies.cta.button}
      primaryHref={getLocalePath(locale, '/contact')}
    />

  </PageLayout>
</BaseLayout>
