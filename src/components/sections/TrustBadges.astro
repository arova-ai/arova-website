---
interface Props {
  title: string;
  items: string[];
}

const { title, items } = Astro.props;
---

<section class="py-24 bg-surface-panel section-gradient-top relative overflow-hidden">
  <div class="orb orb-cyan w-[300px] h-[300px] -top-20 left-1/3 opacity-15" />
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="reveal">
      <div class="flex justify-center mb-5">
        <div class="w-12 h-1 rounded-full bg-gradient-to-r from-primary to-accent" />
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-foreground text-center mb-12 tracking-tight">{title}</h2>
    </div>
    <div class="flex flex-wrap justify-center gap-3 stagger-children">
      {items.map((item) => (
        <div class="flex items-center gap-2.5 px-5 py-3 rounded-full border border-white/6 bg-white/[0.03] hover:border-primary/25 hover:bg-primary/[0.04] transition-all duration-300 group">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 group-hover:scale-110 transition-transform"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
          <span class="text-sm text-muted-foreground group-hover:text-foreground transition-colors">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>
