---
interface Metric {
  value: string;
  label: string;
}

interface Props {
  title: string;
  items: Metric[];
}

const { title, items } = Astro.props;
---

<section class="py-20 bg-surface-panel section-gradient-top">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-foreground text-center mb-10 tracking-tight">{title}</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
      {items.map((item) => (
        <div class="glass-card p-6 text-center">
          <div class="stat-value text-3xl sm:text-4xl mb-2">{item.value}</div>
          <div class="text-sm text-muted-foreground">{item.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
