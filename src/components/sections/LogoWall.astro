---
interface Props {
  title: string;
  logos: string[];
}

const { title, logos } = Astro.props;
---

<section class="py-12 border-y border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm text-muted-foreground mb-6">{title}</p>
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
      {logos.map((logo) => (
        <span class="text-sm font-medium text-muted-foreground/60 hover:text-muted-foreground transition-colors">{logo}</span>
      ))}
    </div>
  </div>
</section>
