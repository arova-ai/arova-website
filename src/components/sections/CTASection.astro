---
import Button from '../ui/Button.astro';

interface Props {
  headline: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const { headline, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="py-28 relative overflow-hidden">
  <!-- Rich gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/8 via-accent/4 to-background" />
  <div class="orb orb-cyan orb-float w-[400px] h-[400px] -top-40 left-1/4 opacity-30" />
  <div class="orb orb-purple w-[300px] h-[300px] -bottom-20 right-1/4 opacity-20" />
  <div class="section-gradient-top absolute inset-0" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground mb-10 text-glow-cyan tracking-tight">{headline}</h2>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      {primaryLabel && primaryHref && (
        <Button href={primaryHref} variant="primary" size="lg">{primaryLabel}</Button>
      )}
      {secondaryLabel && secondaryHref && (
        <Button href={secondaryHref} variant="outline" size="lg">{secondaryLabel}</Button>
      )}
    </div>
  </div>
</section>
