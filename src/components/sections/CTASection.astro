---
import Button from '../ui/Button.astro';

interface Props {
  headline: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const { headline, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="py-24 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-accent/5 to-background" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-foreground mb-8 text-glow-cyan">{headline}</h2>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      {primaryLabel && primaryHref && (
        <Button href={primaryHref} variant="primary" size="lg">{primaryLabel}</Button>
      )}
      {secondaryLabel && secondaryHref && (
        <Button href={secondaryHref} variant="outline" size="lg">{secondaryLabel}</Button>
      )}
    </div>
  </div>
</section>
