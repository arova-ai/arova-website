---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  class?: string;
}

const { title, subtitle, centered = true, class: className = '' } = Astro.props;
---

<div class={`mb-12 ${centered ? 'text-center' : ''} ${className}`}>
  <h2 class="text-3xl sm:text-4xl font-bold text-foreground mb-4">{title}</h2>
  {subtitle && (
    <p class="text-lg text-muted-foreground max-w-3xl mx-auto leading-relaxed">{subtitle}</p>
  )}
</div>
