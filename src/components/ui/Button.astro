---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-medium rounded-full transition-colors';

const variantClasses = {
  primary: 'bg-primary text-white hover:bg-primary/90 glow-cyan',
  outline: 'border border-white/20 text-foreground hover:bg-white/5 hover:border-white/30',
  ghost: 'text-muted-foreground hover:text-foreground hover:bg-white/5',
};

const sizeClasses = {
  sm: 'px-4 py-1.5 text-sm',
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-3 text-base',
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
