---
interface Props {
  glass?: boolean;
  class?: string;
  hover?: boolean;
}

const { glass = true, class: className = '', hover = true } = Astro.props;

const classes = [
  glass ? 'glass-card' : 'bg-card border border-border rounded-xl',
  hover ? 'hover:-translate-y-1 transition-transform duration-300' : '',
  'p-6',
  className,
].join(' ');
---

<div class={classes}>
  <slot />
</div>
