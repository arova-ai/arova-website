---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../../i18n/utils';
import { getTranslation, getLocalePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="bg-surface-dark border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href={getLocalePath(locale)} class="flex items-center mb-4">
          <img src={`${base}/logo-horizontal@2x.png`} alt="Arova" class="h-7" />
        </a>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-sm mb-6">
          {t.footer.vision}
        </p>
        <div class="flex items-center gap-3">
          <a href="#" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="LinkedIn">
            <Icon name="simple-icons:linkedin" size={20} />
          </a>
          <a href="mailto:business@arova-ai.com" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Email">
            <Icon name="lucide:mail" size={20} />
          </a>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-sm font-semibold text-foreground mb-4">{t.footer.product.title}</h3>
        <ul class="space-y-3">
          {t.footer.product.links.map((link) => (
            <li>
              <a href={getLocalePath(locale, link.href)} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-foreground mb-4">{t.footer.company.title}</h3>
        <ul class="space-y-3">
          {t.footer.company.links.map((link) => (
            <li>
              <a href={getLocalePath(locale, link.href)} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-foreground mb-4">{t.footer.contactTitle}</h3>
        <ul class="space-y-3">
          <li>
            <a href="mailto:business@arova-ai.com" class="text-sm text-muted-foreground hover:text-foreground transition-colors flex items-center gap-2">
              <Icon name="lucide:mail" size={14} class="shrink-0" />
              business@arova-ai.com
            </a>
          </li>
          <li class="text-sm text-muted-foreground flex items-start gap-2">
            <Icon name="lucide:map-pin" size={14} class="shrink-0 mt-0.5" />
            {t.about.contact.address}
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-muted-foreground">{t.footer.copyright}</p>
      <div class="flex items-center gap-6">
        <a href="#" class="text-sm text-muted-foreground hover:text-foreground transition-colors">{t.footer.privacy}</a>
        <a href="#" class="text-sm text-muted-foreground hover:text-foreground transition-colors">{t.footer.terms}</a>
      </div>
    </div>
  </div>
</footer>
