---
interface Layer {
  name: string;
  description: string;
}

interface Props {
  layers: Layer[];
}

const { layers } = Astro.props;

const icons = ['💬', '🤖', '⚙️', '🔗', '🛡️', '📊'];
const bgColors = [
  'from-cyan-500/10 to-transparent',
  'from-blue-500/10 to-transparent',
  'from-indigo-500/10 to-transparent',
  'from-violet-500/10 to-transparent',
  'from-purple-500/10 to-transparent',
  'from-fuchsia-500/10 to-transparent',
];
---

<div class="space-y-2">
  {layers.map((layer, i) => (
    <div class={`relative p-4 rounded-xl border border-white/10 bg-gradient-to-r ${bgColors[i]} backdrop-blur-sm hover:border-white/20 transition-colors group`}>
      <div class="flex items-start gap-3">
        <span class="text-xl shrink-0 mt-0.5">{icons[i]}</span>
        <div>
          <div class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors">{layer.name}</div>
          <div class="text-xs text-muted-foreground mt-1">{layer.description}</div>
        </div>
      </div>
      <!-- Layer connector -->
      {i < layers.length - 1 && (
        <div class="absolute -bottom-1.5 left-1/2 -translate-x-1/2 w-px h-3 bg-gradient-to-b from-white/20 to-transparent" />
      )}
    </div>
  ))}
</div>
