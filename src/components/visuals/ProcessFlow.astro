---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<div class="relative">
  <!-- Horizontal connecting line (desktop) -->
  <div class="hidden lg:block absolute top-6 left-[10%] right-[10%] h-0.5 bg-gradient-to-r from-primary via-accent to-primary/30" />

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-4">
    {steps.map((step) => (
      <div class="relative flex flex-col items-center text-center">
        <!-- Number circle -->
        <div class="w-12 h-12 rounded-full border-2 border-primary bg-background flex items-center justify-center text-primary font-bold text-lg mb-4 relative z-10 glow-cyan">
          {step.number}
        </div>
        <h3 class="text-sm font-semibold text-foreground mb-2">{step.title}</h3>
        <p class="text-xs text-muted-foreground leading-relaxed">{step.description}</p>
      </div>
    ))}
  </div>
</div>
