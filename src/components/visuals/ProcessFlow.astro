---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<div class="relative">
  <!-- Horizontal connecting line (desktop) -->
  <div class="hidden lg:block absolute top-7 left-[10%] right-[10%] h-px">
    <div class="w-full h-full bg-gradient-to-r from-primary/60 via-accent/40 to-primary/20" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/30 via-accent/20 to-primary/10 blur-sm" />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-5 stagger-children">
    {steps.map((step) => (
      <div class="relative flex flex-col items-center text-center group">
        <!-- Number circle with double ring -->
        <div class="relative mb-5">
          <div class="w-14 h-14 rounded-full border border-primary/30 bg-background flex items-center justify-center relative z-10 group-hover:border-primary/60 transition-colors">
            <span class="stat-value text-xl">{step.number}</span>
          </div>
          <div class="absolute inset-0 rounded-full bg-primary/5 scale-125 group-hover:scale-150 group-hover:bg-primary/10 transition-all duration-500" />
        </div>
        <h3 class="text-sm font-semibold text-foreground mb-2">{step.title}</h3>
        <p class="text-xs text-muted-foreground leading-relaxed max-w-[180px]">{step.description}</p>
      </div>
    ))}
  </div>
</div>
